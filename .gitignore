# ============================================================
# R session / IDE junk
# ============================================================
.Rproj.user/
.Rhistory
.RData
.RDataTmp
.Ruserdata
*.Rproj
Rplots.pdf

# ============================================================
# Credentials — NEVER commit (GBIF login lives here)
# ============================================================
.Renviron
.Renviron.*

# ============================================================
# Editor / tooling
# ============================================================
.claude/

# ============================================================
# Generated DATA — large, often not redistributable.
# GBIF downloads carry their own license/citation terms.
# Keep the CITATION.txt files (tracked below), drop the rest.
# ============================================================
*.rds
*.zip
gbif_data/*
ano_validation/output/*

# ============================================================
# Generated FIGURES / OUTPUTS — regenerated by the scripts.
# ============================================================
*.png
*.pdf
*.csv
*.xlsx
*.pptx
*.docx

# Windows shortcuts
*.lnk

# Per-group map output folders
maps/
birds/
birds_12reg/
newbirds/
fungi/
fungi_12reg/

# Transient run logs
appendix_run.log
*.log

# ============================================================
# Keep provenance + docs even though the patterns above are broad.
# (git applies the last matching rule, so these un-ignore them.)
# ============================================================
!.gitignore
!**/README.md
!README_gbif_setup.txt
!gbif_data/CITATION.txt
!ano_validation/output/ano_download_citation.txt

# ============================================================
# Thesis appendix figures — intentionally committed so they can be
# linked from the thesis appendix (overrides the broad *.png/*.pdf/*.csv
# ignores above for this folder only).
# ============================================================
!thesis_appendix_figures/
!thesis_appendix_figures/**
